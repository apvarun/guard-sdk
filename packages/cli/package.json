{
  "name": "@guard-sdk/cli",
  "version": "0.5.0",
  "description": "CLI tools for guard-sdk.",
  "keywords": [
    "ai",
    "cli",
    "cost-control",
    "guard-sdk",
    "llm",
    "reporting",
    "usage"
  ],
  "homepage": "https://github.com/apvarun/guard-sdk#readme",
  "bugs": {
    "url": "https://github.com/apvarun/guard-sdk/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apvarun/guard-sdk.git"
  },
  "bin": {
    "guard": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@guard-sdk/core": "workspace:*",
    "@guard-sdk/storage-sqlite": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20"
  }
}
