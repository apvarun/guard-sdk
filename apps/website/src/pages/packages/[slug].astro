---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { getAllPackageDocs, type PackageDoc } from "../../lib/package-docs";

export async function getStaticPaths() {
  const packages = await getAllPackageDocs();
  return packages.map((pkg) => ({
    params: { slug: pkg.slug },
    props: { pkg },
  }));
}

const { pkg } = Astro.props as { pkg: PackageDoc };

if (!pkg) {
  return Astro.redirect("/packages");
}

const groupedExports = pkg.exports.reduce(
  (groups, symbol) => {
    if (!groups[symbol.kind]) {
      groups[symbol.kind] = [];
    }

    groups[symbol.kind].push(symbol);
    return groups;
  },
  {} as Record<string, PackageDoc["exports"]>,
);
const dependencyLinks = pkg.internalDependencies.map((dependency) => ({
  name: dependency,
  href: `/packages/${dependency.replace("@guard-sdk/", "")}`,
}));
---

<BaseLayout title={`${pkg.name} package`} description={pkg.description}>
  <main class="page">
    <SiteHeader currentPath={Astro.url.pathname} />
    <Breadcrumbs
      items={[
        { label: "Home", href: "/" },
        { label: "Packages", href: "/packages" },
        { label: pkg.name },
      ]}
    />

    <section class="section">
      <h1 class="page-title">{pkg.name}</h1>
      <p class="section-copy">{pkg.description}</p>
      <p class="note">Version {pkg.version}</p>
    </section>

    <section class="section">
      <h2>What This Package Covers</h2>
      <p>{pkg.readmeSummary}</p>
    </section>

    <section class="section">
      <h2>Dependencies</h2>
      {dependencyLinks.length > 0 ? (
        <ul class="feature-list">
          {dependencyLinks.map((dependency) => (
            <li>
              <a href={dependency.href}>{dependency.name}</a>
            </li>
          ))}
        </ul>
      ) : (
        <p>This package does not depend on other guard-sdk packages.</p>
      )}
      {pkg.peerDependencies.length > 0 ? (
        <>
          <p class="label">Peer dependencies</p>
          <ul class="feature-list">
            {pkg.peerDependencies.map((dependency) => (
              <li>{dependency}</li>
            ))}
          </ul>
        </>
      ) : null}
    </section>

    <section class="section">
      <h2>Exported API</h2>
      <p>
        Full declarations live in <a href={`/api/${pkg.slug}`}>API Spec for {pkg.name}</a>.
      </p>
      <div class="export-grid">
        {Object.entries(groupedExports).map(([kind, exports]) => (
          <article class="export-group">
            <h3>{kind}</h3>
            <ul>
              {exports?.map((entry) => <li><code>{entry.name}</code></li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
